BEGIN:VEVENT
SUMMARY:起床 · 准备刷题
DTSTART:20260525T063000
DTEND:20260525T070000
RRULE:FREQ=DAILY
DESCRIPTION:洗漱、喝水、醒脑，7点准时坐下
BEGIN:VALARM
TRIGGER:-PT5M
ACTION:DISPLAY
DESCRIPTION:起床，7点刷题
END:VALARM
END:VEVENT

BEGIN:VEVENT
SUMMARY:准备入睡 · 放下手机
DTSTART:20260525T223000
DTEND:20260525T230000
RRULE:FREQ=DAILY
DESCRIPTION:手机放远、灯光调暗，不反思不刷题不回消息
BEGIN:VALARM
TRIGGER:-PT5M
ACTION:DISPLAY
DESCRIPTION:收尾，放下手机
END:VALARM
END:VEVENT

BEGIN:VEVENT

BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//Limber//2026年度全轨日程//CN
X-WR-CALNAME:Limber 2026 全轨日程
X-WR-CALDESC:考公+星龙+习惯+积累——全轨道年度时间管理
CALSCALE:GREGORIAN
BEGIN:VTIMEZONE
TZID:Asia/Shanghai
BEGIN:STANDARD
TZNAME:CST
DTSTART:19700101T000000
TZOFFSETFROM:+0800
TZOFFSETTO:+0800
END:STANDARD
END:VTIMEZONE

# ============================================================
# 每日基础块
# ============================================================

BEGIN:VEVENT
SUMMARY:起床 · 准备刷题
DTSTART:20260525T063000
DTEND:20260525T070000
RRULE:FREQ=DAILY
DESCRIPTION:洗漱、喝水、醒脑\n7:00 准时坐下
BEGIN:VALARM
TRIGGER:-PT5M
ACTION:DISPLAY
DESCRIPTION:起床，7点刷题
END:VALARM
END:VEVENT

BEGIN:VEVENT
SUMMARY:🔴 准备入睡 · 放下手机
DTSTART:20260525T223000
DTEND:20260525T230000
RRULE:FREQ=DAILY
DESCRIPTION:手机放远、灯光调暗\n不反思、不刷题、不回消息
BEGIN:VALARM
TRIGGER:-PT5M
ACTION:DISPLAY
DESCRIPTION:收尾，放下手机
END:VALARM
END:VEVENT

BEGIN:VEVENT
SUMMARY:🔴 熄灯睡觉
DTSTART:20260525T230000
DTEND:20260525T233000
RRULE:FREQ=DAILY
DESCRIPTION:闭眼睡觉\n周日可放宽至24:00
BEGIN:VALARM
TRIGGER:-PT2M
ACTION:DISPLAY
DESCRIPTION:熄灯
END:VALARM
END:VEVENT

# ============================================================
# 考公 · 早间深度块（周一至六 7:00-8:30）
# ============================================================

BEGIN:VEVENT
SUMMARY:🔴 申论小题：写+改
DTSTART:20260525T070000
DTEND:20260525T083000
RRULE:FREQ=WEEKLY;BYDAY=MO,WE
DESCRIPTION:写1篇 → 对照答案逐句改 → 再写一遍 → 记录卡点\n题型轮转：概括→分析→对策
LOCATION:书桌
BEGIN:VALARM
TRIGGER:-PT5M
ACTION:DISPLAY
DESCRIPTION:申论时间，坐下打开题本
END:VALARM
END:VEVENT

BEGIN:VEVENT
SUMMARY:🔴 行测专项突破
DTSTART:20260526T070000
DTEND:20260526T083000
RRULE:FREQ=WEEKLY;BYDAY=TU,TH
DESCRIPTION:弱项模块集中打\n先学方法 → 做专项题组 → 分析错因 → 再做一组
LOCATION:书桌
BEGIN:VALARM
TRIGGER:-PT5M
ACTION:DISPLAY
DESCRIPTION:行测专项，先热身一组
END:VALARM
END:VEVENT

BEGIN:VEVENT
SUMMARY:🔴 申论大作文（隔周）/ 申论小题
DTSTART:20260529T070000
DTEND:20260529T083000
RRULE:FREQ=WEEKLY;BYDAY=FR
DESCRIPTION:大作文周：写框架+论据\n非大作文周：追加一篇小题
LOCATION:书桌
BEGIN:VALARM
TRIGGER:-PT5M
ACTION:DISPLAY
DESCRIPTION:申论大作文日
END:VALARM
END:VEVENT

BEGIN:VEVENT
SUMMARY:🔴 行测套题/模考
DTSTART:20260530T070000
DTEND:20260530T090000
RRULE:FREQ=WEEKLY;BYDAY=SA
DESCRIPTION:半套行测（严格计时）\n每两周一次完整模考（行测+申论）
LOCATION:书桌
BEGIN:VALARM
TRIGGER:-PT5M
ACTION:DISPLAY
DESCRIPTION:行测套题，计时开始
END:VALARM
END:VEVENT

# ============================================================
# 周日晚间 · 周复盘 + 明日计划
# ============================================================

BEGIN:VEVENT
SUMMARY:🌱 自媒体内容创作
DTSTART:20260531T080000
DTEND:20260531T093000
RRULE:FREQ=WEEKLY;BYDAY=SU
DESCRIPTION:睡到自然醒后的第一个整块时间\n写点什么——300字草稿也算\n选题：备考日常/项目管理方法/旧录音带觉察
LOCATION:书桌/沙发
BEGIN:VALARM
TRIGGER:-PT5M
ACTION:DISPLAY
DESCRIPTION:内容创作时间
END:VALARM
END:VEVENT

BEGIN:VEVENT
SUMMARY:📋 周复盘 · 四制回顾
DTSTART:20260531T200000
DTEND:20260531T210000
RRULE:FREQ=WEEKLY;BYDAY=SU
DESCRIPTION:🗂️ 项目：逐项追问进度+卡点\n📋 习惯：打卡数据填表，趋势↗→↘\n👁️ 觉察：旧模式触发几次？叫停几次？\n🌱 积累：还在做吗？有产出吗？\n→ 写入周规划回顾区\n→ 口述明日计划
BEGIN:VALARM
TRIGGER:-PT15M
ACTION:DISPLAY
DESCRIPTION:准备做周复盘
END:VALARM
END:VEVENT

